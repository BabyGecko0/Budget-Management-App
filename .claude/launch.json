{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend"],
      "port": 5173
    },
    {
      "name": "backend",
      "runtimeExecutable": "java",
      "runtimeArgs": [
        "-DSERVER_PORT=8600",
        "-DBUDGET_APP_DATA_DIR=backend/data",
        "-jar",
        "backend/target/budget-app-backend.jar"
      ],
      "port": 8600
    }
  ]
}
